# Vercel Postgres — variáveis injetadas automaticamente ao conectar o banco
# na Vercel (Storage → Postgres). Para desenvolvimento local, rode:
#   vercel env pull .env
# e este arquivo será preenchido com os valores reais.

# URL com pool de conexões (PgBouncer) — usada em runtime pelo Prisma.
POSTGRES_PRISMA_URL="postgres://user:password@host:5432/db?pgbouncer=true&connect_timeout=15"

# Conexão direta (sem pool) — usada pelas migrations (prisma migrate deploy).
POSTGRES_URL_NON_POOLING="postgres://user:password@host:5432/db?sslmode=require"
